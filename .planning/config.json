{
  "mode": "yolo",
  "granularity": "coarse",
  "parallelization": false,
  "commit_docs": true,
  "model_profile": "inherit",
  "response_language": "pt-BR",
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "nyquist_validation": true,
    "tdd_mode": true,
    "auto_advance": true,
    "_auto_chain_active": true
  },
  "quality_gates": {
    "compile": "python -m compileall -q app.py markflow tests",
    "lint": "python -m ruff check . && python -m black --check . && python -m flake8 app.py markflow tests",
    "typecheck": "python -m mypy markflow",
    "unit": "pytest -m unit -q --no-cov",
    "integration": "pytest -m \"integration and not slow\" -q --no-cov",
    "functional": "pytest -m functional -q --no-cov",
    "coverage": "pytest -q && python -m coverage report --fail-under=100"
  }
}
