{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://markflow/services/api/contracts/events/progress-event.v1.schema.json",
  "title": "MarkFlow Progress Event v1",
  "type": "object",
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "enum": [
        "progress.event.v1"
      ]
    },
    "schema_version": {
      "type": "string",
      "enum": [
        "v1"
      ]
    },
    "job_id": {
      "type": "string",
      "minLength": 1
    },
    "page_number": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "emitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "causation_id": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "stream": {
      "type": "string",
      "enum": [
        "mf.progress.v1"
      ]
    },
    "payload": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "accepted",
            "started",
            "processing_page",
            "completed_page",
            "retrying"
          ]
        },
        "progress_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "status",
        "progress_percent",
        "message"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "event_id",
    "event_type",
    "schema_version",
    "job_id",
    "page_number",
    "attempt",
    "emitted_at",
    "correlation_id",
    "causation_id",
    "stream",
    "payload"
  ],
  "additionalProperties": false
}
