# OpenAI-compatible LLM provider settings
# Keep this file local; never commit real keys.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com
LLM_PROVIDER_PRESET=custom
LLM_ZAI_PLAN=general
LLM_PROVIDER_NAME=

# Provider-specific API keys (official naming)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
ZAI_API_KEY=

# Optional fixed model id (if empty, model is selected dynamically)
LLM_MODEL=

# Optional: path to local Tesseract binary if not on PATH
# TESSERACT_CMD=C:\\Program Files\\Tesseract-OCR\\tesseract.exe
