{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://markflow/services/worker/contracts/events/event-envelope.v1.schema.json",
  "title": "MarkFlow Event Envelope v1",
  "type": "object",
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "enum": [
        "dispatch.command.v1",
        "progress.event.v1",
        "result.event.v1"
      ]
    },
    "schema_version": {
      "type": "string",
      "enum": [
        "v1"
      ]
    },
    "job_id": {
      "type": "string",
      "minLength": 1
    },
    "page_number": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "emitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "causation_id": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "required": [
    "event_id",
    "event_type",
    "schema_version",
    "job_id",
    "page_number",
    "attempt",
    "emitted_at",
    "correlation_id",
    "causation_id"
  ],
  "additionalProperties": false
}
