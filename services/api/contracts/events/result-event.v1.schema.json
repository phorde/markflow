{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://markflow/services/api/contracts/events/result-event.v1.schema.json",
  "title": "MarkFlow Result Event v1",
  "type": "object",
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "enum": [
        "result.event.v1"
      ]
    },
    "schema_version": {
      "type": "string",
      "enum": [
        "v1"
      ]
    },
    "job_id": {
      "type": "string",
      "minLength": 1
    },
    "page_number": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "emitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "causation_id": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "stream": {
      "type": "string",
      "enum": [
        "mf.result.v1"
      ]
    },
    "payload": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "success",
            "partial",
            "failed"
          ]
        },
        "output_uri": {
          "type": "string",
          "minLength": 1
        },
        "metrics": {
          "type": "object",
          "properties": {
            "processed_pages": {
              "type": "integer",
              "minimum": 0
            },
            "accepted_pages": {
              "type": "integer",
              "minimum": 0
            },
            "needs_reprocess_pages": {
              "type": "integer",
              "minimum": 0
            }
          },
          "required": [
            "processed_pages",
            "accepted_pages",
            "needs_reprocess_pages"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "status",
        "output_uri",
        "metrics"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "event_id",
    "event_type",
    "schema_version",
    "job_id",
    "page_number",
    "attempt",
    "emitted_at",
    "correlation_id",
    "causation_id",
    "stream",
    "payload"
  ],
  "additionalProperties": false
}
